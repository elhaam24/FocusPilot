{
  "name": "focuspilot",
  "version": "1.0.0",
  "description": "An educational game to train focus and attention in children.",
  "main": "server/index.js",
  "scripts": {
    "init-project": "npm install && cd frontend && npm install",
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix frontend"
  },
  "dependencies": {
    "@google/generative-ai": "^0.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
